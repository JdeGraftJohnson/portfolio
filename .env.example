# --- Contact form (footer Email button) ---

# Cloudflare Turnstile -- get keys at https://dash.cloudflare.com/?to=/:account/turnstile
# Public site key (safe to ship to browser)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key (server only, NEVER ship to client)
TURNSTILE_SECRET_KEY=

# Resend -- get API key at https://resend.com/api-keys
RESEND_API_KEY=

# Optional: override the From address. Default is onboarding@resend.dev (Resend sandbox).
# To send from a custom address you must verify the domain in Resend first.
# CONTACT_FROM_EMAIL=contact@johndegraft.app
